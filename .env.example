# ─── Django ───────────────────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=cambia-esto-por-una-clave-segura-minimo-50-caracteres
ALLOWED_HOSTS=localhost 127.0.0.1

# ─── Base de datos (Railway provee DATABASE_URL automáticamente) ──────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Redis (Railway provee REDIS_URL automáticamente) ────────────────────────
REDIS_URL=redis://default:password@host:6379

# ─── Email (Brevo) ────────────────────────────────────────────────────────────
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu_email@sentinelxo.dev
EMAIL_HOST_PASSWORD=tu_api_key_brevo
DEFAULT_FROM_EMAIL=soporte@perseustechnology.dev

# ─── Sentinel XO ─────────────────────────────────────────────────────────────
SENTINEL_COMPANY_NAME=Sentinel XO
SENTINEL_SUPPORT_EMAIL=soporte@perseustechnology.dev

# ─── Brevo Webhook ───────────────────────────────────────────────────────────
BREVO_WEBHOOK_SECRET=tu_clave_secreta_brevo

# ─── CSRF (Railway lo setea automáticamente via RAILWAY_PUBLIC_DOMAIN) ───────
# CSRF_TRUSTED_ORIGINS=https://tu-app.railway.app
